# ---------- Server ----------
PORT=4000
NODE_ENV=development
# Public URL of THIS backend, used to build the M-Pesa callback URL and
# told to FreeRADIUS/rlm_rest as the base for authorize/accounting calls.
PUBLIC_BASE_URL=https://api.ivynexwifi.co.ke

# ---------- MongoDB ----------
MONGO_URI=mongodb://127.0.0.1:27017/ivynex_wifi

# ---------- Safaricom Daraja (M-Pesa) ----------
# sandbox while testing, production once you've gone live with Safaricom
MPESA_ENV=sandbox
MPESA_BASE_URL_SANDBOX=https://sandbox.safaricom.co.ke
MPESA_BASE_URL_PRODUCTION=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
# Lipa Na M-Pesa Online shortcode (Paybill/Till) + passkey from the Daraja portal
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
# Safaricom will POST results here — must be a public HTTPS URL
MPESA_CALLBACK_URL=${PUBLIC_BASE_URL}/api/payments/mpesa/callback

# ---------- FreeRADIUS <-> backend shared secret ----------
# The rlm_rest module on the FreeRADIUS box must send this in an
# X-Radius-Secret header on every authorize/accounting call, so random
# people on the internet can't forge RADIUS decisions against your API.
RADIUS_REST_SHARED_SECRET=change_this_to_a_long_random_string

# ---------- MikroTik RouterOS API (optional, for CoA / disconnect-on-expiry) ----------
MIKROTIK_HOST=192.168.88.1
MIKROTIK_API_PORT=8728
MIKROTIK_USER=ivynex-api
MIKROTIK_PASSWORD=change_this
